{
  "name": "@redhat-cloud-services/nxtcm-rosa-hcp-wizard",
  "version": "6.0.0",
  "description": "PatternFly wizard component for ROSA HCP cluster creation in ACM and OCM",
  "author": "Red Hat",
  "license": "Apache-2.0",
  "main": "dist/index.umd.js",
  "module": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "components",
    "patternfly",
    "acm",
    "ocm",
    "red-hat",
    "insights",
    "typescript",
    "ui"
  ],
  "private": true,
  "peerDependencies": {
    "@patternfly/react-code-editor": "^6.5.1",
    "js-yaml": "^4.1.0",
    "monaco-editor": ">=0.36.0",
    "monaco-yaml": "^5.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "semver": "^7.7.4"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cidr-tools": "^11.3.5",
    "handlebars": "^4.7.8",
    "ip-cidr": "^3.1.0",
    "react-hook-form": "^7.74.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@patternfly/react-code-editor": "^6.5.1",
    "@patternfly/react-core": "^6.5.1",
    "@patternfly/react-icons": "^6.5.1",
    "@patternfly/react-table": "^6.5.1",
    "js-yaml": "^4.1.0",
    "monaco-editor": ">=0.36.0",
    "monaco-yaml": "^5.4.1"
  },
  "scripts": {
    "prepack": "cp ../../LICENSE LICENSE",
    "postpack": "rm -f LICENSE",
    "build": "tsc && NXTCM_LIB_NAME=NXTCM-ROSA-HCP-WIZARD vite build --config ../../vite.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint --config ../../.eslintrc.json 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint --config ../../.eslintrc.json 'src/**/*.{ts,tsx}' --fix",
    "prettier:check": "prettier --check 'src/**/*.{js,ts,mjs,jsx,tsx}'",
    "prettier:fix": "prettier --write 'src/**/*.{js,ts,mjs,jsx,tsx}'",
    "test": "jest --config ../../jest.config.js packages/nxtcm-rosa-hcp-wizard",
    "test:ct": "playwright test -c ../../playwright-ct.config.ts packages/nxtcm-rosa-hcp-wizard",
    "allthethings": "npm run prettier:fix && npm run lint:fix && npm run type-check && npm run test && npm run test:ct"
  }
}
