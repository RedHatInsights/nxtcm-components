apiVersion: controlplane.cluster.x-k8s.io/v1beta2
kind: ROSAControlPlane
metadata:
  name: '{{{cluster.name}}}'
  namespace: '{{{cluster.name}}}'
spec:
  rosaClusterName: '{{{cluster.name}}}'
  version: '{{{cluster.cluster_version}}}'
  versionGate: WaitForAcknowledge
  channelGroup: stable
  region: '{{{cluster.region}}}'
{{#if cluster.billing_account_id}}
  billingAccount: '{{{cluster.billing_account_id}}}'
{{/if}}
  endpointAccess: {{#eq cluster.cluster_privacy "external"}}Public{{else}}Private{{/eq}}
{{#if cluster.installer_role_arn}}
  installerRoleARN: '{{{cluster.installer_role_arn}}}'
{{/if}}
{{#if cluster.support_role_arn}}
  supportRoleARN: '{{{cluster.support_role_arn}}}'
{{/if}}
{{#if cluster.worker_role_arn}}
  workerRoleARN: '{{{cluster.worker_role_arn}}}'
{{/if}}
{{#if cluster.byo_oidc_config_id}}
  oidcID: '{{{cluster.byo_oidc_config_id}}}'
{{/if}}
  network:
    machineCIDR: '{{{cluster.network_machine_cidr}}}'
    serviceCIDR: '{{{cluster.network_service_cidr}}}'
    podCIDR: '{{{cluster.network_pod_cidr}}}'
    hostPrefix: {{stripSlash cluster.network_host_prefix}}
    networkType: OVNKubernetes
{{#if cluster.machine_pools_subnets}}
  subnets:
  {{#each cluster.machine_pools_subnets}}
    {{#if this.machine_pool_subnet}}
    - '{{{this.machine_pool_subnet}}}'
    {{/if}}
  {{/each}}
{{/if}}
{{#if cluster.machine_type}}
  defaultMachinePoolSpec:
    instanceType: '{{{cluster.machine_type}}}'
    volumeSize: {{{cluster.compute_root_volume}}}
  {{#if cluster.autoscaling}}
    autoscaling:
      minReplicas: {{{cluster.min_replicas}}}
      maxReplicas: {{{cluster.max_replicas}}}
  {{/if}}
{{/if}}
{{#if cluster.etcd_encryption}}
  {{#if cluster.etcd_key_arn}}
  etcdEncryptionKMSARN: '{{{cluster.etcd_key_arn}}}'
  {{/if}}
{{/if}}
  credentialsSecretRef:
    name: '{{{cluster.name}}}-creds'