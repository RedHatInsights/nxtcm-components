{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "packageRules": [
    {
      "description": "Disable all major updates",
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Group PatternFly packages across all workspaces",
      "matchPackageNames": ["@patternfly/**"],
      "groupName": "patternfly"
    },
    {
      "description": "Group React packages across all workspaces",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "react"
    },
    {
      "description": "Group Monaco editor + YAML LSP packages so version-coupled updates land in one reviewable PR",
      "matchPackageNames": ["monaco-editor", "monaco-yaml", "@monaco-editor/react", "monaco-types"],
      "groupName": "monaco"
    },
    {
      "description": "Treat 0.x minor updates as major breaking changes for monaco-editor",
      "matchPackageNames": ["monaco-editor"],
      "matchCurrentVersion": "/^0\\./",
      "matchUpdateTypes": ["minor"],
      "enabled": false
    }
  ],
  "reviewers": ["nitin-dhevar", "kdoberst", "davidaznaur", "jloss-redhat", "vishsanghishetty", "brandonthanhnguyen"],
  "reviewersSampleSize": 2,
  "dependencyDashboard": true,
  "minimumReleaseAge": "4 days",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "labels": ["dependencies"],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "commitMessageSuffix": "[SECURITY]",
    "prCreation": "immediate"
  }
}
